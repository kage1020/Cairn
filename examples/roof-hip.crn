@cairn 2026.06
@requires version>=1.20

# Minimum hip-roof example.
# Demonstrates: kind=hip on a square footprint, four slopes converging on
# a single apex cap.

theme pavilion:
  slot floor -> @oak_planks
  slot wall  -> @cobblestone
  slot roof  -> @spruce_stairs

struct roof_hip size=5x5
  floor mat_slot=floor
  walls mat_slot=wall height=3
  roof  kind=hip mat_slot=roof overhang=1
