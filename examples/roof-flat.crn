@cairn 2026.06
@requires version>=1.20

# Minimum flat-roof example.
# Demonstrates: kind=flat single-layer deck of spruce planks at wall_top+1,
# overhang extends the deck past the walls.

theme outpost:
  slot floor -> @oak_planks
  slot wall  -> @cobblestone
  slot roof  -> @spruce_planks

struct roof_flat size=6x6
  floor mat_slot=floor
  walls mat_slot=wall height=4
  roof  kind=flat mat_slot=roof overhang=1
